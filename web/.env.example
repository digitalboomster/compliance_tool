# In-browser mock API (default). Set to "true" only when a real server is available.
# VITE_USE_REAL_API=true

# Optional: override API origin (no trailing slash).
# On Vercel (single project: web + /api), leave unset — the app uses same-origin /api.
# Local dev: leave unset — Vite proxies /api → http://localhost:3000.
# Only set if the SPA is served from a different host than the API.
# VITE_API_URL=

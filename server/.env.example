# Local Postgres (e.g. docker compose up -d from repo root)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/compliance?schema=public"

JWT_SECRET="change-this-to-a-long-random-string-in-production"
PORT=3000
UPLOAD_DIR="./uploads"
CORS_ORIGIN="http://localhost:5173"

# Vercel Blob — required for document uploads when the API runs on Vercel (serverless).
# Leave unset for local disk storage under UPLOAD_DIR.
# BLOB_READ_WRITE_TOKEN=
